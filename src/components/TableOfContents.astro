---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="bg-neutral-50 border border-neutral-200 rounded-lg p-5 mb-8">
    <p class="text-sm font-semibold text-neutral-900 mb-3">Table of Contents</p>
    <ul class="space-y-2 text-sm">
      {filteredHeadings.map((heading) => (
        <li class={heading.depth === 3 ? 'ml-4' : ''}>
          <a
            href={`#${heading.slug}`}
            class="text-neutral-600 hover:text-primary-600 transition-colors"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
