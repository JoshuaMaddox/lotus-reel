---
import Schema from './Schema.astro';
import { generateBreadcrumbSchema } from '../utils/schema';

interface Props {
  items: { name: string; href?: string }[];
}

const { items } = Astro.props;
const siteUrl = 'https://lotusreel.com';

const schemaItems = items.map((item) => ({
  name: item.name,
  url: item.href ? new URL(item.href, siteUrl).href : siteUrl,
}));
---

<nav aria-label="Breadcrumb" class="py-4">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ol class="flex flex-wrap items-center gap-2 text-sm text-neutral-500">
      {items.map((item, index) => (
        <li class="flex items-center gap-2">
          {index > 0 && (
            <svg class="w-4 h-4 text-neutral-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          )}
          {index === items.length - 1 ? (
            <span class="text-neutral-900 font-medium">{item.name}</span>
          ) : (
            <a href={item.href || '/'} class="hover:text-primary-600 transition-colors">{item.name}</a>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>

<Schema schemas={[generateBreadcrumbSchema(schemaItems)]} />
