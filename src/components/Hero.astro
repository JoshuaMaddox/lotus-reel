---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  size?: 'default' | 'large';
}

const {
  title,
  subtitle,
  ctaText = 'Get a Free Quote',
  ctaHref = '/contact/',
  secondaryCtaText,
  secondaryCtaHref,
  size = 'default',
} = Astro.props;

const paddingClass = size === 'large' ? 'py-20 lg:py-32' : 'py-16 lg:py-24';
---

<section class={`relative bg-neutral-900 text-white ${paddingClass}`}>
  <div class="absolute inset-0 bg-gradient-to-br from-neutral-900 via-neutral-800 to-primary-900/30"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 leading-tight">
      {title}
    </h1>
    {subtitle && (
      <p class="text-lg sm:text-xl text-neutral-300 max-w-3xl mx-auto mb-10">
        {subtitle}
      </p>
    )}
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={ctaHref}
        class="inline-flex items-center px-8 py-4 bg-primary-700 text-white font-semibold rounded-lg hover:bg-primary-800 transition-colors text-lg"
      >
        {ctaText}
      </a>
      {secondaryCtaText && secondaryCtaHref && (
        <a
          href={secondaryCtaHref}
          class="inline-flex items-center px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors text-lg"
        >
          {secondaryCtaText}
        </a>
      )}
    </div>
  </div>
</section>
