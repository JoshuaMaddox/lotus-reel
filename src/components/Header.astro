---
import { mainNav } from '../data/navigation';
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-neutral-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0" aria-label="Lotus Reel - Home">
        <img src="/images/logo.svg" alt="Lotus Reel" class="h-8 lg:h-10 w-auto" width="120" height="32" />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {mainNav.map((item) => (
          item.children ? (
            <div class="relative group">
              <button
                class="px-3 py-2 text-sm font-medium text-neutral-700 hover:text-primary-600 transition-colors flex items-center gap-1"
                aria-expanded="false"
                aria-haspopup="true"
              >
                {item.label}
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-white rounded-lg shadow-lg border border-neutral-200 py-2 min-w-[220px]">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-2 text-sm text-neutral-700 hover:bg-primary-50 hover:text-primary-700 transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium text-neutral-700 hover:text-primary-600 transition-colors"
            >
              {item.label}
            </a>
          )
        ))}
      </nav>

      <!-- CTA + Mobile Menu Button -->
      <div class="flex items-center gap-3">
        <a
          href="/contact/"
          class="hidden sm:inline-flex items-center px-5 py-2.5 bg-primary-700 text-white text-sm font-semibold rounded-lg hover:bg-primary-800 transition-colors"
        >
          Get a Free Quote
        </a>
        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-neutral-700 hover:text-primary-600"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-neutral-200 bg-white">
    <div class="px-4 py-4 space-y-1">
      {mainNav.map((item) => (
        item.children ? (
          <div>
            <div class="px-3 py-2 text-sm font-semibold text-neutral-500 uppercase tracking-wider">
              {item.label}
            </div>
            {item.children.map((child) => (
              <a
                href={child.href}
                class="block px-3 py-2 pl-6 text-sm text-neutral-700 hover:text-primary-600 hover:bg-primary-50 rounded-md"
              >
                {child.label}
              </a>
            ))}
          </div>
        ) : (
          <a
            href={item.href}
            class="block px-3 py-2 text-sm font-medium text-neutral-700 hover:text-primary-600 hover:bg-primary-50 rounded-md"
          >
            {item.label}
          </a>
        )
      ))}
      <a
        href="/contact/"
        class="block w-full text-center px-5 py-3 mt-3 bg-primary-700 text-white text-sm font-semibold rounded-lg hover:bg-primary-800"
      >
        Get a Free Quote
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
