---
interface Props {
  quote: string;
  name: string;
  title: string;
  company: string;
  rating: number;
}

const { quote, name, title, company, rating } = Astro.props;
---

<div class="bg-white rounded-xl border border-neutral-200 p-6 lg:p-8">
  <!-- Stars -->
  <div class="flex gap-1 mb-4">
    {Array.from({ length: 5 }).map((_, i) => (
      <svg class={`w-5 h-5 ${i < rating ? 'text-accent-400' : 'text-neutral-200'}`} fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>
  <!-- Quote -->
  <blockquote class="text-neutral-700 mb-6 leading-relaxed">"{quote}"</blockquote>
  <!-- Attribution -->
  <div>
    <p class="font-semibold text-neutral-900">{name}</p>
    <p class="text-sm text-neutral-500">{title}, {company}</p>
  </div>
</div>
