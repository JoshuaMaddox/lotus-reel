---
import { formatDate } from '../utils/format-date';

interface Props {
  title: string;
  description: string;
  href: string;
  publishDate: Date;
  readingTime: number;
  category?: string;
}

const { title, description, href, publishDate, readingTime, category } = Astro.props;
---

<article class="group bg-white rounded-xl border border-neutral-200 overflow-hidden hover:border-primary-300 hover:shadow-lg transition-all duration-200">
  <!-- Placeholder image area -->
  <div class="aspect-video bg-neutral-100 flex items-center justify-center">
    <svg class="w-12 h-12 text-neutral-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
    </svg>
  </div>
  <div class="p-5">
    {category && (
      <span class="text-xs font-semibold text-primary-700 uppercase tracking-wider">{category}</span>
    )}
    <h3 class="mt-1 text-lg font-bold text-neutral-900 group-hover:text-primary-700 transition-colors">
      <a href={href}>{title}</a>
    </h3>
    <p class="mt-2 text-sm text-neutral-600 line-clamp-2">{description}</p>
    <div class="mt-4 flex items-center gap-3 text-xs text-neutral-500">
      <time datetime={publishDate.toISOString()}>{formatDate(publishDate)}</time>
      <span>&middot;</span>
      <span>{readingTime} min read</span>
    </div>
  </div>
</article>
