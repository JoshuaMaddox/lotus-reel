---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Lotus Reel"
  description="The page you're looking for doesn't exist. Find your way back to our video production services."
  noindex={true}
>
  <section class="py-20 lg:py-32 text-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-6xl font-extrabold text-primary-700 mb-4">404</p>
      <h1 class="text-3xl font-bold text-neutral-900 mb-4">Page Not Found</h1>
      <p class="text-neutral-600 mb-8">The page you're looking for doesn't exist or has been moved. Let's get you back on track.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="px-6 py-3 bg-primary-700 text-white font-semibold rounded-lg hover:bg-primary-800 transition-colors">
          Go to Homepage
        </a>
        <a href="/services/" class="px-6 py-3 border border-neutral-300 text-neutral-700 font-semibold rounded-lg hover:bg-neutral-50 transition-colors">
          View Services
        </a>
        <a href="/contact/" class="px-6 py-3 border border-neutral-300 text-neutral-700 font-semibold rounded-lg hover:bg-neutral-50 transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
