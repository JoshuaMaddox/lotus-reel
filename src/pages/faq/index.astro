---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTASection from '../../components/CTASection.astro';
import Schema from '../../components/Schema.astro';
import { faqItems } from '../../data/faq';
import { generateFAQSchema } from '../../utils/schema';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'FAQ' },
];

const categories = [...new Set(faqItems.map((item) => item.category))];
const schemas = [generateFAQSchema(faqItems)];
---

<BaseLayout
  title="FAQ — Video Production Questions Answered | Lotus Reel"
  description="Frequently asked questions about video production in Bangkok. Pricing, process, equipment, timelines, and more. Get answers from Lotus Reel's production team."
  schemas={schemas}
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold text-neutral-900 mb-4">Frequently Asked Questions</h1>
      <p class="text-lg text-neutral-600 mb-12">
        Everything you need to know about working with Lotus Reel. Can't find your answer? <a href="/contact/" class="text-primary-700 hover:text-primary-800 font-medium">Contact us</a>.
      </p>

      {categories.map((category) => (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-neutral-900 mb-6">{category}</h2>
          <div class="space-y-3">
            {faqItems.filter((item) => item.category === category).map((item) => (
              <details class="group bg-white border border-neutral-200 rounded-lg">
                <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-left font-medium text-neutral-900 hover:text-primary-700 transition-colors">
                  <span>{item.question}</span>
                  <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-6 pb-4 text-neutral-600 leading-relaxed">
                  {item.answer}
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <CTASection title="Still Have Questions?" subtitle="We're happy to help. Reach out for a free consultation." />
</BaseLayout>
