---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import MultiStepForm from '../../components/islands/MultiStepForm';
import { organizationData } from '../../utils/schema';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Contact' },
];
---

<BaseLayout
  title="Contact Lotus Reel — Get a Video Production Quote Fast"
  description="Contact Lotus Reel for a fast video production quote. Based in Bangkok, Thailand. Reach us via email, phone, Line, or WhatsApp. Response within 24 hours."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Form -->
        <div class="lg:col-span-2">
          <h1 class="text-4xl font-extrabold text-neutral-900 mb-4">Get a Quote Fast</h1>
          <p class="text-lg text-neutral-600 mb-8">
            Tell us about your project and we'll get back to you within 24 hours with a detailed, no-obligation quote.
          </p>
          <MultiStepForm client:visible />
        </div>

        <!-- Contact Info Sidebar -->
        <div class="space-y-8">
          <div>
            <h2 class="text-lg font-bold text-neutral-900 mb-4">Other Ways to Reach Us</h2>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-neutral-900">Email</p>
                  <a href={`mailto:${organizationData.email}`} class="text-sm text-primary-700 hover:text-primary-800">{organizationData.email}</a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-neutral-900">Phone</p>
                  <p class="text-sm text-neutral-600">Available on request</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-neutral-900">Line / WhatsApp</p>
                  <p class="text-sm text-neutral-600">Available for instant messaging</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-neutral-900">Location</p>
                  <p class="text-sm text-neutral-600">Bangkok, Thailand</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-neutral-50 rounded-lg border border-neutral-200 p-6">
            <h3 class="font-bold text-neutral-900 mb-2">What Happens Next?</h3>
            <ol class="space-y-3 text-sm text-neutral-600">
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center text-xs font-bold">1</span>
                <span>We review your project details within 24 hours</span>
              </li>
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center text-xs font-bold">2</span>
                <span>We schedule a free consultation call</span>
              </li>
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center text-xs font-bold">3</span>
                <span>You receive a detailed proposal and quote</span>
              </li>
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center text-xs font-bold">4</span>
                <span>We kick off your project!</span>
              </li>
            </ol>
          </div>

          <div class="bg-primary-50 rounded-lg border border-primary-200 p-6 text-center">
            <p class="text-2xl font-bold text-primary-800">4.9/5</p>
            <div class="flex justify-center gap-1 my-2">
              {Array.from({ length: 5 }).map(() => (
                <svg class="w-5 h-5 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <p class="text-sm text-primary-700">from 47+ client reviews</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
